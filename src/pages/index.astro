---
import BackBusinessCard from "../components/index/BackBusinessCard.astro";
import FrontBusinessCard from "../components/index/FrontBusinessCard.astro";
import Layout from "../layouts/Layout.astro";
import { db } from "../lib/database";

const title = `${db.name} ${db.surname} | ${db.profession}`;
const description = `${db.name} ${db.surname} is a ${db.profession} based in Italy, specializing in custom web applications, cloud architecture on AWS, and freelance software development with modern technologies like Next.js, React, TypeScript, and Spring Boot.`;
const ogTitle = `${db.name} ${db.surname} | ${db.profession}`;
---

<Layout pageTitle={title} pageDescription={description} ogTitle={ogTitle}>
  <div class="container">
    <h1 class="sr-only">{`${db.name} ${db.surname} | ${db.profession}`}</h1>
    <p class="sr-only">
      {
        `I'm ${db.name} ${db.surname}, a freelance software developer based in Italy. I build custom web applications, backend systems, and cloud architecture on AWS using TypeScript, React, Next.js, and Spring Boot. Available for freelance and contract development work.`
      }
    </p>

    <div class="card-container">
      <input
        type="checkbox"
        id="input-checkbox-card"
        class="input-checkbox-card"
        aria-label="Toggle card flip"
      />

      <label for="input-checkbox-card" class="label-card">
        <div class="card">
          <div class="card-face card-front">
            <FrontBusinessCard />
          </div>

          <div class="card-face card-back">
            <BackBusinessCard />
          </div>
        </div>
      </label>
    </div>
  </div>

  <p class="flip-hint" aria-hidden="true">Click card to flip</p>
</Layout>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const card = document.querySelector<HTMLElement>(".card");
    if (card) {
      card.style.animation = "spin 3s ease-in-out forwards";

      setTimeout(() => {
        card.style.animation = "";
      }, 3000);
    }
  });
</script>

<style>
  .container {
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    z-index: 10;
    padding: var(--space-4);
  }

  .card-container {
    width: min(400px, 90vw);
    aspect-ratio: 16 / 10;
    perspective: 1200px;
    position: relative;
  }

  .input-checkbox-card {
    position: absolute;
    opacity: 0;
    pointer-events: none;
    width: 0;
    height: 0;
  }

  .label-card {
    display: block;
    width: 100%;
    height: 100%;
    cursor: pointer;
    position: relative;
  }

  .card {
    width: 100%;
    height: 100%;
    position: relative;
    transition: transform 0.8s cubic-bezier(0.4, 0.2, 0.2, 1);
    transform-style: preserve-3d;
    border-radius: var(--radius-md);
  }

  .input-checkbox-card:checked + .label-card .card {
    transform: rotateY(180deg);
  }

  .card-face {
    position: absolute;
    width: 100%;
    height: 100%;
    backface-visibility: hidden;
    display: flex;
    flex: 1;
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
    box-shadow: var(--shadow-card);
    overflow: hidden;
  }

  .card-front {
    background: var(--gradient-card-front);
  }

  .card-back {
    background: var(--gradient-card-back);
    transform: rotateY(180deg);
  }

  .flip-hint {
    position: fixed;
    bottom: var(--space-5);
    right: clamp(var(--space-5), 23vw, 30rem);
    margin: 0;
    font-family: var(--font-mono);
    font-size: var(--text-2xs);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  @media (max-width: 900px) {
    .flip-hint {
      right: var(--space-5);
    }
  }

  @media (max-width: 480px) {
    .flip-hint {
      bottom: var(--space-4);
      right: var(--space-4);
    }
  }

  @keyframes spin {
    0% {
      transform: rotateY(0deg);
    }
    100% {
      transform: rotateY(360deg);
    }
  }

  @media (max-width: 480px) {
    .card-container {
      width: min(340px, 92vw);
      aspect-ratio: 3 / 2;
    }
  }

  @media (max-height: 480px) {
    .container {
      min-height: 100dvh;
      height: auto;
      padding: var(--space-6) var(--space-4);
    }
  }
</style>
