---
import { db } from "../../lib/database";
---

<div class="container">
  <div class="credentials">
    <p class="eyebrow">{db.profession}</p>
    <h1 class="name">{`${db.name} ${db.surname}`}</h1>
  </div>

  <div class="divider"></div>

  <div class="contacts">
    <a href={`tel:${db.phone}`}>{db.phone}</a>
    <a href={`mailto:${db.email}`}>{db.email}</a>
    <a href={`https://${db.website}`} target="_blank" rel="noopener noreferrer"
      >{db.website}</a
    >
  </div>

  <a
    href={db.certification}
    target="_blank"
    rel="noopener noreferrer"
    class="aws-badge"
  >
    AWS Certified
  </a>
</div>

<style>
  .container {
    display: flex;
    flex: 1;
    flex-direction: column;
    justify-content: space-between;
    padding: var(--space-5);
  }

  .eyebrow {
    margin: 0 0 var(--space-2);
    font-family: var(--font-mono);
    font-size: var(--text-2xs);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .name {
    margin: 0;
    font-family: var(--font-serif);
    font-size: var(--text-xl);
    font-weight: 700;
    line-height: 1.2;
    color: var(--color-text-primary);
  }

  .divider {
    height: 2px;
    flex-shrink: 0;
    margin: var(--space-4) 0;
    background: var(--gradient-divider);
  }

  .contacts {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    flex: 1;
  }

  .contacts a {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-secondary);
  }

  .contacts a:hover {
    color: var(--color-text-primary);
    text-shadow: none;
  }

  .aws-badge {
    align-self: flex-end;
    font-family: var(--font-mono);
    font-size: var(--text-2xs);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--color-accent);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: var(--space-1) var(--space-3);
  }

  .aws-badge:hover {
    color: var(--color-accent-bright);
    border-color: var(--color-accent);
    text-shadow: none;
  }

  @media (max-width: 480px) {
    .container {
      padding: var(--space-4);
    }

    .name {
      font-size: var(--text-lg);
    }
  }
</style>
